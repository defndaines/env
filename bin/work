#!/bin/sh
# Work tmux session launcher. ACTIVELY USED.
# Creates (or attaches to) a 'work' session with a 3-pane layout.
if ! tmux has-session -t work 2>/dev/null
then
  # cd ~/work-dir
  tmux new-session -s work -n work -d
  tmux split-window -h -t work
  tmux split-window -v -t work
fi
tmux attach -t work

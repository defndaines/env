#!/bin/sh
# New machine initialization. Run once after cloning this repo to ~/src/env.
# Sets up dotfile symlinks, vim bin directory, shell function library, and Terminal profile.
# Safe to re-run: symlinks are overwritten, directories are not removed.
#
# Prerequisites (install manually before running):
#   Xcode CLT:  xcode-select --install
#   Homebrew:   /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

set -e
REPO="$HOME/src/env"

if ! xcode-select -p >/dev/null 2>&1; then
  echo "Error: Xcode Command Line Tools not installed. Run: xcode-select --install"
  exit 1
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "Error: Homebrew not installed. See https://brew.sh"
  exit 1
fi

link() {
  ln -sf "$REPO/$1" "$HOME/$2"
}

echo "Linking dotfiles ..."
link .editrc       .editrc
link .fzf.zsh      .fzf.zsh
link .gitignore    .gitignore
link .inputrc      .inputrc
link .osx_aliases  .osx_aliases
link .psqlrc       .psqlrc
link .sqliterc     .sqliterc
link .tmux.conf    .tmux.conf
link .vimrc        .vimrc
link .zshenv       .zshenv
link .zshrc        .zshrc

echo "Linking notes ..."
link dev-notes.md    dev-notes.md
link elixir-notes.md elixir-notes.md
link psql-notes.sql  psql-notes.sql
link five            five

echo "Setting up shell function library ..."
mkdir -p "$HOME/lib/shell"
link lib/shell/functions.sh lib/shell/functions.sh

echo "Installing Homebrew packages ..."
brew bundle --file="$REPO/Brewfile"

echo "Installing vim extras ..."

mkdir -p "$HOME/.vim/pack/bundle/opt"
mkdir -p "$HOME/.vim/pack/bundle/start"
vim_start="$HOME/.vim/pack/bundle/start"
vim_clone() {
  name="$1"; url="$2"
  if [ ! -d "$vim_start/$name" ]; then
    git clone "$url" "$vim_start/$name"
  else
    echo "  $name already present, skipping"
  fi
}
vim_clone ale              git@github.com:dense-analysis/ale
vim_clone fzf              git@github.com:junegunn/fzf.git
vim_clone fzf.vim          git@github.com:junegunn/fzf.vim.git
vim_clone nerdcommenter    git@github.com:scrooloose/nerdcommenter.git
vim_clone rainbow          git@github.com:luochen1990/rainbow.git
vim_clone spelunker.vim    git@github.com:kamykn/spelunker.vim.git
vim_clone tabular          git@github.com:godlygeek/tabular.git
vim_clone vim-elixir       git@github.com:elixir-editors/vim-elixir.git
vim_clone vim-endwise      git@github.com:tpope/vim-endwise.git
vim_clone vim-grepper      git@github.com:mhinz/vim-grepper.git
vim_clone vim-lsp          git@github.com:prabirshrestha/vim-lsp.git
vim_clone vim-lsp-ale      git@github.com:rhysd/vim-lsp-ale.git
vim_clone vim-repeat       git@github.com:tpope/vim-repeat.git
vim_clone vim-sandwich     git@github.com:machakann/vim-sandwich.git
vim_clone vim-slime        git@github.com:jpalardy/vim-slime.git

mkdir -p "$HOME/.vim"
ln -sf "$REPO/.vim/bin" "$HOME/.vim/bin"

mkdir -p "$HOME/.vim/ftplugin"
ln -sf "$REPO/.vim/ftplugin/htmltemplate.vim" "$HOME/.vim/ftplugin/htmltemplate.vim"

echo "Setting up Terminal profile ..."
"$REPO/bin/setup-terminal"

echo "Done. Note: copy .gitconfig manually and update email/work URLs as needed."

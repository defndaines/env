# macOS shell aliases. ACTIVELY USED. Sourced by .zshrc.

# basics
########
alias bu='brew update | tee ${HOME}/.brew_update_log && brew upgrade | tee ${HOME}/.brew_upgrade_log'
alias clera='clear'
alias grpe='grep'
alias dds='find . -name .DS_Store | xargs rm'
alias f='find . -name'
alias ot='open -a TextEdit'
alias excel='open -a Microsoft\ Excel'
alias preview='open -a preview'
alias utc='date -u +"%Y-%m-%dT%H:%M:%SZ"'
alias ts='date -u +"%Y%m%d%H%M%S"'
alias ll='ls -lhtr'
alias h='history'
alias eighty='echo ........10........20........30........40........50........60........70........80'
alias sixtyfive='echo ........10........20........30........40........50........60...65'

alias book='cd ~/src/dal/gr'

# git
#####
alias b='git branch'
alias co='git checkout'
alias co-='git checkout --'
alias d='git diff'
alias g.='git add .'
alias g='git'
alias ga='git add'
alias ga-p='git add -p'
alias gcm='git commit --verbose'
alias ggrep='git grep'
alias glog='git glog'
alias gph='git push'
alias gph-f='git push --force-with-lease'
alias gpl='git pull'
alias pd='git patdiff'
alias st='git status'
alias dfmt='git diff --name-only | xargs mix format'
alias gtags='git fetch --tags'
alias wip='git wip main'
alias rbh='git rebase -i HEAD~2'
alias restore='git restore --staged'
alias vist='vim $(git diff --name-only && git ls-files --others --exclude-standard)'
alias ffetch='git fetch origin && git reset --hard origin/$(git rev-parse --abbrev-ref HEAD)'

# tmux
######
alias ta='tmux attach -t'
alias tl='tmux list-sessions'
alias tmid='tmate show-messages'
alias wrok='work'

# postgresql
############
alias pgup='pg_ctl -D /usr/local/var/postgres start'
alias pgdown='pg_ctl -D /usr/local/var/postgres stop'

# elixir
# ######
alias ism='iex -S mix'
alias mr='mix run --no-halt'
alias mps='mix phx.server'
alias dia='mix dialyzer'
alias credo='mix credo'
alias stf='mix format $(git diff --name-only)'
alias stt='mix test $(git diff main --name-only| sort| grep "_test.exs")'
